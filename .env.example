# ============================================
# AdGen AI — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=adgen_ai
POSTGRES_USER=adgen
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://adgen:changeme_in_production@postgres:5432/adgen_ai

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (validation only)
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=adgen-auth

# OpenAI (Phase 2)
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini

# Google Cloud / Vertex AI (Phase 3)
GOOGLE_CLOUD_PROJECT=placeholder
GOOGLE_CLOUD_LOCATION=us-central1
# Path to GCP service account key file on the host machine
# The file is mounted into containers at /app/credentials/gcp-key.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json
GCS_BUCKET_NAME=adgen-images

# Meta Ads (Phase 4)
META_APP_ID=placeholder
META_APP_SECRET=placeholder

# Notifications (Phase 7)
SENDGRID_API_KEY=placeholder

# AI Sync mode (true for development — calls AI service directly; false for Celery async)
USE_SYNC_AI=true

# General
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Frontend
VITE_API_GATEWAY=http://localhost
